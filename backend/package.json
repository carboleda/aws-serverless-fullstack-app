{
  "name": "aws-serverless-fullstack-app",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "serverless offline start --stage dev --reloadHandler",
    "dynamodb:start": "docker compose up",
    "deploy:dev": "serverless deploy --stage dev",
    "undeploy:dev": "serverless remove --stage dev",
    "deploy:prod": "serverless deploy --stage prod",
    "undeploy:prod": "serverless remove --stage prod"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.585.0",
    "@aws-sdk/lib-dynamodb": "^3.585.0",
    "express": "^4.19.2",
    "reflect-metadata": "^0.2.2",
    "serverless-http": "^3.2.0",
    "tsyringe": "^4.10.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.5.0",
    "serverless-dynamodb-local": "^0.2.40",
    "serverless-offline": "^14.5.0"
  }
}
